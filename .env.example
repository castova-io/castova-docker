# Castova environment — copy to .env and fill in values
# The installer generates this automatically.
# Only edit if you need to change configuration after install.

PANEL_DOMAIN=panel.example.com
NODE_ENV=production

# Database
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://castova:changeme@postgres:5432/castova

# Redis
REDIS_URL=redis://redis:6379

# MQTT
MQTT_URL=mqtt://mosquitto:1883

# Auth
JWT_SECRET=changeme-use-random-32-char-string

# LiveKit (Castova Studio)
LIVEKIT_API_KEY=castova-key
LIVEKIT_API_SECRET=changeme-livekit-secret-min-32-chars
LIVEKIT_URL=wss://panel.example.com:7880

# Studio bridge
BRIDGE_SECRET=changeme-bridge-secret

# TURN server
TURN_SECRET=changeme-turn-secret

# Storage encryption (AES-256-GCM key, 32 bytes hex — generated by installer)
STORAGE_ENCRYPTION_KEY=

# AI features (optional)
ANTHROPIC_API_KEY=

# Licensing (fill in when ready)
KEYGEN_ACCOUNT_ID=
KEYGEN_PRODUCT_TOKEN=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
